<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta http-equiv="x-ua-compatible" content="ie=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <title>{{ title | safe }}</title>

        <link rel="stylesheet" href="/dist/style.latest.css">
        <style>
            /* Accessibility skip-link: off-screen until keyboard-focused. */
            .skip-link{position:absolute;left:-9999px;top:auto;z-index:1000}
            .skip-link:focus{left:8px;top:8px;padding:8px 12px;background:#fff;border:1px solid #ccc}
            /* No-JS fallback nav: only rendered when zfin-chrome.js can't inject
               the real header (JS disabled / non-rendering crawler). */
            .nojs-nav{padding:8px 12px;border-bottom:1px solid #ccc;font-family:sans-serif;font-size:14px}
            .nojs-nav ul{list-style:none;margin:0 0 6px;padding:0;display:flex;flex-wrap:wrap;gap:4px 16px}
            .nojs-nav a{text-decoration:none}
        </style>

        <script src="https://cdn.jsdelivr.net/npm/jquery@1.12.4/dist/jquery.min.js"></script>
        <script src="/dist/vendor-common.latest.js"></script>
        <script src="/dist/zfin-common.latest.js"></script>
        <script src="/analytics.js"></script>
    </head>
    <body>
        <a class="skip-link" href="#main">Skip to main content</a>
        <noscript>
            <nav class="nojs-nav" aria-label="ZFIN navigation">
                <ul>
                    <li><a href="/">ZFIN Home</a></li>
                    <li><a href="/action/marker/search">Genes / Clones</a></li>
                    <li><a href="/action/expression/search">Expression</a></li>
                    <li><a href="/action/fish/search">Mutants / Tg</a></li>
                    <li><a href="/action/antibody/search">Antibodies</a></li>
                    <li><a href="/action/ontology/search">Anatomy / GO / Disease / Chemical</a></li>
                    <li><a href="/action/publication/search">Publications</a></li>
                    <li><a href="/downloads">Downloads</a></li>
                    <li><a href="/zf_info/zfbook/zfbk.html">The Zebrafish Book</a></li>
                </ul>
                <form method="GET" action="/search" role="search">
                    <input type="text" name="q" placeholder="Search ZFIN" aria-label="Search ZFIN">
                    <button type="submit">Search</button>
                </form>
            </nav>
        </noscript>
        <div data-zfin-chrome-header></div>
        <main id="main">
{{ content | trim | safe }}
        </main>
        <div data-zfin-chrome-footer></div>
        <!-- Prev/next page nav, built from the TOC JSON. `defer` so it never
             blocks render; inserts a nav bar only when the page is in a spine. -->
        <script defer src="/zf_info/toc/booknav.js"></script>
    </body>
</html>
